# Demo deployment environment for a single Ubuntu VPS running Docker Compose.
# Copy this file to `deploy.env`, rotate all secrets, and replace YOUR_VPS_IP.

POSTGRES_DB=exam_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

FRONTEND_PORT=3000
BACKEND_PORT=4000

APP_URL=http://YOUR_VPS_IP:3000
CORS_ORIGIN=http://YOUR_VPS_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:4000/api

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_RESET_SECRET=replace-with-a-long-random-reset-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_RESET_TTL=30m

# Rotate the current development key before any real deployment.
GEMINI_API_KEY=replace-with-a-rotated-production-key
